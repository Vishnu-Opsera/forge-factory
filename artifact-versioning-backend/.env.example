# PostgreSQL connection string (supports pgBouncer pooling)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/artifact_versioning

# AWS credentials — must have S3 read/write on S3_BUCKET_NAME
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 bucket for artifact storage
S3_BUCKET_NAME=s3-bucket-name

# Override for LocalStack in dev
S3_ENDPOINT=http://localhost:4566
# Set to 'true' when using LocalStack
S3_FORCE_PATH_STYLE=true

# OpenAI key for text-embedding-3-small
OPENAI_API_KEY=sk-...

# HTTP server port (default 3000)
PORT=3000

# development | test | production
NODE_ENV=development

# Max upload size in bytes (default 10 MB)
MAX_UPLOAD_BYTES=10485760

# S3 presigned URL TTL in seconds (default 15 min)
PRESIGNED_URL_TTL_SECONDS=900
